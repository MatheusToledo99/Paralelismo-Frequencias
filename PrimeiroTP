from numba import cuda
import numpy
from numpy import random
import numpy

@cuda.jit
def my_kernel(io_array):
    # Thread id in a 1D block
    tx = cuda.threadIdx.x
    # Block id in a 1D grid
    ty = cuda.blockIdx.x
    # Block width, i.e. number of threads per block
    bw = cuda.blockDim.x
    
    # Compute flattened index inside the array
    pos = tx + ty * bw

    num = 0
    count = 0
    if pos < io_array.size:
      num = io_array[pos]
      for n in io_array: 
        if num == n:
          count = count + 1
      io_array[pos] = count
      count = 0      



print('Matheus Toledo' +'\n' + 'GitHub'+ '\n' +  'Algoritmo de frequências dos números aleatórios de forma paralela em GPU' + '\n\n')
    
# vetor com números
data = random.randint(1, high = 11, size = (10))
print ('Numeros aleatorios:') 
print(data)
print('\n')

# números de threads por bloco
threads_per_block = 32

# número de blocos por grid
blocks_per_grid = ( data.size + (threads_per_block - 1) )

# iniciando o kernel
my_kernel[blocks_per_grid, threads_per_block](data)

# mostra o resultado
print ('Frequencias desses numeros aleatorios em sequencia ao vetor acima:')
print(data)
